---
import { experience } from '../data/experience';
---

<section id="experience" class="py-20 px-6 bg-gray-900/30">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-white mb-2 fade-in">Experience</h2>
    <div class="w-10 h-0.5 bg-teal-400 mb-12 fade-in"></div>

    <div class="space-y-12">
      {
        experience.map((entry) => (
          <div class="fade-in grid sm:grid-cols-[200px_1fr] gap-4">
            <div class="text-sm text-gray-500 pt-1 shrink-0">
              <p class="font-medium text-gray-400">{entry.period}</p>
              <p class="mt-1">{entry.location}</p>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white">{entry.role}</h3>
              <p class="text-teal-400 text-sm font-medium mb-3">{entry.company}</p>
              <ul class="space-y-2">
                {entry.bullets.map((bullet) => (
                  <li class="text-gray-400 text-sm leading-relaxed flex gap-2">
                    <span class="text-teal-400 mt-1 shrink-0">▸</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
