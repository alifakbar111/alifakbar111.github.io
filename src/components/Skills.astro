---
import { skills } from '../data/skills';
---

<section id="skills" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-white mb-2 fade-in">Skills</h2>
    <div class="w-10 h-0.5 bg-teal-400 mb-12 fade-in"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        skills.map((group) => (
          <div class="fade-in">
            <h3 class="text-xs font-semibold text-teal-400 uppercase tracking-widest mb-3">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="px-2.5 py-1 text-xs text-gray-300 bg-gray-800 rounded-md border border-gray-700">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
