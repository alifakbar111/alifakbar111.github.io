---
const links = [
  {
    label: 'Email',
    href: 'mailto:alifakbar111@gmail.com',
    sublabel: 'alifakbar111@gmail.com',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/alifakbar111',
    sublabel: 'github.com/alifakbar111',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/alifakbar111/',
    sublabel: 'linkedin.com/in/alifakbar111',
  },
];
---

<section id="contact" class="py-20 px-6 bg-gray-900/30">
  <div class="max-w-5xl mx-auto fade-in">
    <h2 class="text-2xl font-bold text-white mb-2">Contact</h2>
    <div class="w-10 h-0.5 bg-teal-400 mb-10"></div>

    <p class="text-gray-400 text-lg mb-10 max-w-xl">
      Open to new opportunities. Feel free to reach out via email or connect on LinkedIn.
    </p>

    <div class="flex gap-4">
      {/* Email */}
      <a
        href="mailto:alifakbar111@gmail.com"
        aria-label="Email"
        class="p-3 border border-gray-800 rounded-xl text-gray-400 hover:border-teal-400/50 hover:text-teal-400 hover:bg-gray-900 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>

      {/* GitHub */}
      <a
        href="https://github.com/alifakbar111"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="p-3 border border-gray-800 rounded-xl text-gray-400 hover:border-teal-400/50 hover:text-teal-400 hover:bg-gray-900 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
          <path d="M9 18c-4.51 2-5-2-7-2"/>
        </svg>
      </a>

      {/* LinkedIn */}
      <a
        href="https://www.linkedin.com/in/alifakbar111/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="p-3 border border-gray-800 rounded-xl text-gray-400 hover:border-teal-400/50 hover:text-teal-400 hover:bg-gray-900 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect width="4" height="12" x="2" y="9"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<footer class="py-8 px-6 text-center text-gray-600 text-xs border-t border-gray-800">
  Built with Astro & Tailwind CSS · Muhammad Alif Akbar © 2026
</footer>
